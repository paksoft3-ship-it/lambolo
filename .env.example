# ------------------------------------------------------------------
# LAMBOLO — environment variables
# Copy this file to `.env.local` and fill in the values you need.
# ------------------------------------------------------------------

# Public site URL (used for canonical + Open Graph metadata).
NEXT_PUBLIC_SITE_URL=https://lambolo.com

# ---- Waitlist / Partnership storage ------------------------------
# Backends are tried in this order: Neon/Postgres -> Supabase -> dev mock.
# If none is set: dev uses an in-memory mock; production returns a clear
# configuration error (no silent data loss).

# RECOMMENDED: Neon / any Postgres. On Vercel + Neon this is injected for you.
# Run the schema once:  npm run db:setup   (uses db/schema.sql)
DATABASE_URL=

# Optional (legacy) Supabase REST backend — only used if DATABASE_URL is unset.
# The service-role key is SERVER-ONLY. It is never sent to the browser.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: override the default table names.
# LEADS_WAITLIST_TABLE=waitlist_leads
# LEADS_PARTNERSHIP_TABLE=partnership_leads

# ---- Admin panel (/admin) ----------------------------------------
# Single shared password used to sign in to the admin panel.
# REQUIRED for the admin panel to work in production.
ADMIN_PASSWORD=

# Secret used to sign the admin session cookie (HMAC). Use a long random
# string. If omitted, ADMIN_PASSWORD is used as the signing secret.
# Generate one with:  openssl rand -base64 32
ADMIN_SESSION_SECRET=
